<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.controlsfx.control.*?>

<!-- Alliance Championship — info panel integrated as expandable section -->
<BorderPane maxHeight="Infinity" maxWidth="Infinity"
            HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"
            xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    styleClass="task-page-scroll">
            <VBox spacing="16" styleClass="task-page-root" maxWidth="Infinity">

                <!-- Main Championship Configuration -->
                <VBox styleClass="content-card">
                    <HBox maxWidth="Infinity" styleClass="header-purple">
                        <CheckBox fx:id="checkBoxEnableChampionship" mnemonicParsing="false"
                                  style="-fx-font-size: 15px; -fx-font-weight: bold;"
                                  text="Enable Alliance Championship" />
                    </HBox>
                    <VBox spacing="10" styleClass="task-section-inner">
                        <Label styleClass="task-card-description"
                               text="Configure Alliance Championship deployment position and troop composition."
                               wrapText="true" />

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label minWidth="120.0" styleClass="task-field-label" text="Position" />
                            <ComboBox fx:id="comboBoxPosition" prefWidth="150.0" />
                        </HBox>

                        <CheckBox fx:id="checkBoxOverrideCurrentDeploy" mnemonicParsing="false"
                                  text="Override Current Deployment" />

                        <Separator style="-fx-opacity: 0.25;" />

                        <Label styleClass="task-field-label" text="Troop Mix Percentages" />
                        
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label minWidth="120.0" styleClass="task-field-label" text="Infantry %" />
                            <TextField fx:id="textfieldInfantryPercentage" prefWidth="80.0" promptText="33" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label minWidth="120.0" styleClass="task-field-label" text="Lancers %" />
                            <TextField fx:id="textfieldLancersPercentage" prefWidth="80.0" promptText="33" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label minWidth="120.0" styleClass="task-field-label" text="Marksmen %" />
                            <TextField fx:id="textfieldMarksmansPercentage" prefWidth="80.0" promptText="34" />
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Quick Guide -->
                <TitledPane text="Quick Guide" expanded="false"
                            styleClass="content-card" collapsible="true">
                    <VBox spacing="6" style="-fx-padding: 10;">
                        <Label styleClass="task-info-panel-bullet"
                               text="• Select your preferred lane position (LEFT, CENTER, or RIGHT)." wrapText="true" />
                        <Label styleClass="task-info-panel-bullet"
                               text="• Configure troop mix percentages (should total 100%)." wrapText="true" />
                        <Label styleClass="task-info-panel-bullet"
                               text="• Override deployment will replace your current setup." wrapText="true" />
                    </VBox>
                </TitledPane>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
