<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.controlsfx.control.*?>

<!-- Bear Trap — info panel merged into main content as collapsible TitledPane -->
<BorderPane maxHeight="Infinity" maxWidth="Infinity"
            HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"
            xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    styleClass="task-page-scroll">
            <VBox spacing="16" styleClass="task-page-root" maxWidth="Infinity">

                <!-- Main Enable Card -->
                <VBox styleClass="content-card">
                    <HBox maxWidth="Infinity" styleClass="header-yellow">
                        <CheckBox fx:id="checkBoxEnableBearTrap" mnemonicParsing="false"
                                  style="-fx-font-size: 15px; -fx-font-weight: bold;"
                                  text="Enable Bear Trap" />
                    </HBox>
                    <VBox spacing="10" styleClass="task-section-inner">
                        <Label styleClass="task-card-description"
                               text="Schedule preparation, choose the trap, and control rally behavior for the event."
                               wrapText="true" />

                        <FlowPane hgap="18" vgap="10" alignment="CENTER_LEFT">
                            <VBox spacing="6" prefWidth="240">
                                <Label styleClass="task-field-label" text="Next Bear Trap (UTC)" />
                                <TextField fx:id="textFieldScheduleDateTime"
                                           promptText="dd-MM-yyyy HH:mm" />
                                <Label fx:id="labelDateTimeError"
                                       style="-fx-font-size: 11px; -fx-text-fill: #ff4444;"
                                       text="" wrapText="true" />
                            </VBox>
                            <VBox spacing="6" prefWidth="120">
                                <Label styleClass="task-field-label" text="Prep minutes" />
                                <TextField fx:id="textFieldPreparationTime" prefWidth="100.0"
                                           promptText="5" />
                            </VBox>
                        </FlowPane>
                    </VBox>
                </VBox>

                <!-- Preparation and Trap Target side-by-side -->
                <HBox alignment="TOP_LEFT" spacing="14">

                    <VBox styleClass="content-card" HBox.hgrow="ALWAYS">
                        <HBox maxWidth="Infinity" styleClass="header-blue">
                            <Label text="Preparation" />
                        </HBox>
                        <VBox spacing="10" styleClass="task-section-inner">
                            <CheckBox fx:id="checkBoxActivePets" mnemonicParsing="false"
                                      text="Active Pets" />
                            <CheckBox fx:id="checkBoxRecallTroops" mnemonicParsing="false"
                                      text="Recall Gather Troops" />
                        </VBox>
                    </VBox>

                    <VBox styleClass="content-card" HBox.hgrow="ALWAYS">
                        <HBox maxWidth="Infinity" styleClass="header-red">
                            <Label text="Trap Target" />
                        </HBox>
                        <VBox spacing="10" styleClass="task-section-inner">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label minWidth="90.0" styleClass="task-field-label" text="Trap" />
                                <ComboBox fx:id="comboBoxTrapNumber" prefWidth="100.0" />
                            </HBox>
                            <CheckBox fx:id="checkBoxCallRally" mnemonicParsing="false"
                                      text="Call Own Rally" />
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label minWidth="90.0" styleClass="task-field-label"
                                       text="Rally Flag" />
                                <ComboBox fx:id="comboBoxRallyFlag" prefWidth="100.0" />
                            </HBox>
                            <CheckBox fx:id="checkBoxEnableJoin" mnemonicParsing="false"
                                      text="Enable Join Rally" />
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label minWidth="90.0" styleClass="task-field-label"
                                       text="Join Flag" />
                                <CheckComboBox fx:id="checkComboBoxJoinFlag" prefWidth="100.0" />
                            </HBox>
                        </VBox>
                    </VBox>
                </HBox>

                <!-- Quick guide as collapsible TitledPane instead of BorderPane.right -->
                <TitledPane text="Quick Guide" expanded="false" collapsible="true"
                            styleClass="content-card">
                    <VBox spacing="6" style="-fx-padding: 10;">
                        <Label styleClass="task-info-panel-bullet"
                               text="• Use UTC time in dd-MM-yyyy HH:mm format." wrapText="true" />
                        <Label styleClass="task-info-panel-bullet"
                               text="• Prep time starts before trap activation." wrapText="true" />
                        <Label styleClass="task-info-panel-bullet"
                               text="• Rally options can call your own rally or join others."
                               wrapText="true" />
                        <Label styleClass="task-info-panel-bullet"
                               text="• Gathering and autojoin are restored after the event."
                               wrapText="true" />
                    </VBox>
                </TitledPane>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
