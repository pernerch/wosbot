<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- Bulk Update Dialog — restructured header and action bar -->
<BorderPane prefHeight="460.0" prefWidth="520.0" styleClass="bulk-update-dialog"
            xmlns="http://javafx.com/javafx/11.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.frostguard.app.panel.profile.BulkUpdateDialogController">

    <!-- Header: HBox row instead of VBox stack -->
    <top>
        <VBox spacing="4" styleClass="bulk-update-header">
            <padding>
                <Insets bottom="12" left="24" right="24" top="22" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="14">
                <Label styleClass="bulk-update-title" text="Copy Settings to Profiles" />
                <Label fx:id="lblTemplateProfile" styleClass="bulk-update-source"
                       text="Using profile as the source" />
            </HBox>
            <Label styleClass="bulk-update-note"
                   text="Choose the destination profiles that should receive this configuration set."
                   wrapText="true" />
            <Separator style="-fx-opacity: 0.2;" />
        </VBox>
    </top>

    <!-- Profile list with selection controls -->
    <center>
        <VBox spacing="10">
            <padding>
                <Insets bottom="8" left="24" right="24" top="12" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <Button fx:id="btnSelectAll" mnemonicParsing="false"
                        onAction="#handleSelectAll" text="Select all" />
                <Button fx:id="btnDeselectAll" mnemonicParsing="false"
                        onAction="#handleDeselectAll" text="Clear" />
            </HBox>
            <ScrollPane fitToWidth="true" prefHeight="260.0"
                        styleClass="bulk-update-list-frame">
                <VBox fx:id="vboxProfileList" fillWidth="true" spacing="8.0">
                    <padding>
                        <Insets bottom="12" left="12" right="12" top="12" />
                    </padding>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>

    <!-- Action bar restructured -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="bulk-update-actions">
            <padding>
                <Insets bottom="20" left="24" right="24" top="14" />
            </padding>
            <Button fx:id="btnCancel" mnemonicParsing="false"
                    onAction="#handleCancel" text="Cancel" />
            <Button fx:id="btnUpdate" defaultButton="true" mnemonicParsing="false"
                    onAction="#handleUpdate" styleClass="accent-button"
                    text="Apply settings" />
        </HBox>
    </bottom>
</BorderPane>
