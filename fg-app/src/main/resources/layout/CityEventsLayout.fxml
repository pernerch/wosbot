<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- City Events — StackPane root with VBox form rows replacing GridPane -->
<StackPane maxHeight="Infinity" maxWidth="Infinity"
           HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"
           xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                styleClass="task-page-scroll">
        <VBox spacing="14" styleClass="task-page-root" maxWidth="Infinity">

            <VBox styleClass="content-card">
                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" styleClass="header-yellow">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: -fg-bg-app; -fx-font-size: 13px;"
                           text="City Events &amp; Missions" />
                </HBox>
                <VBox spacing="12" styleClass="task-section-inner">
                    <Label styleClass="task-card-description"
                           text="Configure automated tasks for internal city events" wrapText="true" />
                    <Separator style="-fx-opacity: 0.25;" />

                    <!-- Daily missions row -->
                    <HBox alignment="CENTER_LEFT" spacing="14">
                        <CheckBox fx:id="checkBoxDailyMission" graphicTextGap="6.0"
                                  mnemonicParsing="false" text="Claim daily missions" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label styleClass="task-field-label" text="Offset:" />
                        <TextField fx:id="textfieldDailyMissionOffset" prefWidth="80.0" />
                    </HBox>

                    <CheckBox fx:id="checkBoxAutoScheduleDailyMission" graphicTextGap="6.0"
                              mnemonicParsing="false" text="Auto schedule daily mission claim" />

                    <Separator style="-fx-opacity: 0.25;" />

                    <!-- Exploration row -->
                    <CheckBox fx:id="checkBoxDoExploration" graphicTextGap="6.0"
                              mnemonicParsing="false" text="Do Exploration" />

                    <HBox alignment="CENTER_LEFT" spacing="14">
                        <CheckBox fx:id="checkBoxExplorationChest" graphicTextGap="6.0"
                                  mnemonicParsing="false" text="Claim exploration chest" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label styleClass="task-field-label" text="Offset:" />
                        <TextField fx:id="textfieldExplorationOffset" prefWidth="80.0" />
                    </HBox>

                    <Separator style="-fx-opacity: 0.25;" />

                    <!-- Mail rewards row -->
                    <HBox alignment="CENTER_LEFT" spacing="14">
                        <CheckBox fx:id="checkBoxMailRewards" graphicTextGap="6.0"
                                  mnemonicParsing="false" text="Claim mail rewards" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label styleClass="task-field-label" text="Offset:" />
                        <TextField fx:id="textfieldMailOffset" prefWidth="80.0" />
                    </HBox>

                    <Separator style="-fx-opacity: 0.25;" />

                    <!-- Life essence and weekly scroll -->
                    <HBox alignment="CENTER_LEFT" spacing="14">
                        <CheckBox fx:id="checkBoxLifeEssence" graphicTextGap="6.0"
                                  mnemonicParsing="false" text="Claim life essence" />
                        <CheckBox fx:id="checkBoxWeeklyScroll" graphicTextGap="6.0"
                                  mnemonicParsing="false" text="Buy weekly scroll" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label styleClass="task-field-label" text="Offset:" />
                        <TextField fx:id="textfieldLifeEssenceOffset" prefWidth="80.0" />
                    </HBox>

                    <Separator style="-fx-opacity: 0.25;" />

                    <!-- Crystal lab and RFC -->
                    <CheckBox fx:id="checkBoxCrystalLabFC" graphicTextGap="6.0"
                              mnemonicParsing="false" text="Claim crystal lab FC" />

                    <HBox alignment="CENTER_LEFT" spacing="14">
                        <CheckBox fx:id="checkBoxDailyDiscountedRFC" graphicTextGap="6.0"
                                  mnemonicParsing="false" text="Claim daily 50% RFC" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label styleClass="task-field-label" text="Monday refinement:" />
                        <ComboBox fx:id="comboBoxMondayRefinements" prefWidth="80.0" />
                    </HBox>

                    <!-- War academy -->
                    <CheckBox fx:id="checkBoxWarAcademyShards" graphicTextGap="6.0"
                              mnemonicParsing="false" text="Claim war academy crystal shards" />
                </VBox>
            </VBox>

        </VBox>
    </ScrollPane>
</StackPane>
