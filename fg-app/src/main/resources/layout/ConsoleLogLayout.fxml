<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="Infinity" maxWidth="Infinity"
      spacing="6" style="-fx-padding: 8 16 16 16;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
   <children>

      <!-- Top Search + Filter Bar -->
      <HBox alignment="CENTER_LEFT" spacing="12" styleClass="control-top-bar">
         <children>
            <!-- Search Field -->
            <HBox alignment="CENTER_LEFT" spacing="0" HBox.hgrow="ALWAYS" styleClass="log-search-wrapper">
               <children>
                  <FontIcon iconLiteral="mdi2m-magnify" iconSize="16" iconColor="#636a75" />
                  <TextField fx:id="txtSearchLogs" promptText="Filter log entries..."
                             HBox.hgrow="ALWAYS" styleClass="control-search-field" />
                  <Button fx:id="btnClearSearch" text="✕" onAction="#handleClearSearch"
                          styleClass="search-clear-btn" />
               </children>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Profile Filter -->
            <ComboBox fx:id="comboBoxProfileFilter" prefWidth="150" styleClass="control-filter-combo" />

            <!-- Level Filter -->
            <ComboBox fx:id="comboBoxLevelFilter" prefWidth="120" styleClass="control-filter-combo" />
         </children>
      </HBox>

      <!-- Log Table -->
      <TableView fx:id="tableviewLogMessages" VBox.vgrow="ALWAYS"
                 maxHeight="Infinity" maxWidth="Infinity">
        <columns>
          <TableColumn fx:id="columnTimeStamp" editable="false" minWidth="80.0"
                       prefWidth="160.0" sortable="false" text="TIMESTAMP" style="-fx-alignment: CENTER;" />
          <TableColumn fx:id="columnLevel" editable="false" minWidth="60.0"
                       prefWidth="70.0" sortable="false" text="LEVEL" style="-fx-alignment: CENTER;" />
          <TableColumn fx:id="columnMessage" editable="false" maxWidth="Infinity"
                       minWidth="200.0" sortable="false" text="MESSAGE" style="-fx-alignment: CENTER_LEFT;" />
          <TableColumn fx:id="columnProfile" editable="false" minWidth="80.0"
                       prefWidth="110.0" sortable="false" text="PROFILE" style="-fx-alignment: CENTER;" />
          <TableColumn fx:id="columnTask" editable="false" minWidth="80.0"
                       prefWidth="140.0" sortable="false" text="TASK" style="-fx-alignment: CENTER;" />
        </columns>
        <columnResizePolicy>
           <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
      </TableView>

      <!-- Bottom Toolbar -->
      <HBox alignment="CENTER_LEFT" spacing="12" styleClass="control-bottom-bar">
         <children>
            <!-- DEBUG checkbox stays bottom-left -->
            <CheckBox fx:id="checkboxDebug" mnemonicParsing="false" text="DEBUG" />

            <Region HBox.hgrow="ALWAYS" />

            <!-- Action Buttons -->
            <HBox spacing="8">
                <Button fx:id="buttonOpenLogFolder" mnemonicParsing="false"
                        onAction="#handleButtonOpenLogFolder" text="Open Logs Folder"
                        styleClass="action-button-logs" />
                <Button fx:id="buttonClearLogs" mnemonicParsing="false"
                        onAction="#handleButtonClearLogs" text="Clear Logs"
                        styleClass="action-button-clear">
                    <graphic>
                        <FontIcon iconLiteral="mdi2d-delete-outline" iconSize="16" iconColor="white" />
                    </graphic>
                </Button>
            </HBox>
         </children>
      </HBox>

   </children>
</VBox>
