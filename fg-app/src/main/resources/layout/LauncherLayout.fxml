<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
            maxHeight="Infinity" maxWidth="Infinity"
            style="-fx-background-color: #11141a; -fx-border-color: #30363d; -fx-border-width: 1;">

    <!-- TOP: Title bar using BorderPane instead of StackPane for different hierarchy -->
    <top>
        <StackPane fx:id="titleBar" minHeight="32" prefHeight="32" maxHeight="32"
                   styleClass="custom-title-bar"
                   onMousePressed="#handleTitleBarMousePressed"
                   onMouseDragged="#handleTitleBarMouseDragged"
                   onMouseReleased="#handleTitleBarMouseReleased"
                   onMouseClicked="#handleTitleBarMouseClicked">

            <!-- Title label centered in stack -->
            <Label fx:id="labelWindowTitle" text="Whiteout Survival Bot"
                   styleClass="title-bar-text"
                   mouseTransparent="true"
                   StackPane.alignment="CENTER" />

            <!-- Window controls pinned right -->
            <HBox alignment="CENTER_RIGHT" styleClass="title-bar-controls"
                  StackPane.alignment="CENTER_RIGHT" pickOnBounds="false">
                <Button fx:id="btnMinimize" text="—" styleClass="title-bar-btn"
                        onAction="#handleMinimize" focusTraversable="false" />
                <Button fx:id="btnMaximize" text="☐" styleClass="title-bar-btn"
                        onAction="#handleMaximize" focusTraversable="false" />
                <Button fx:id="btnClose" text="✕" styleClass="title-bar-btn, title-bar-close"
                        onAction="#handleClose" focusTraversable="false" />
            </HBox>
        </StackPane>
    </top>

    <!-- LEFT: Sidebar with reorganized internal structure -->
    <left>
        <VBox styleClass="nav-sidebar">

            <VBox fx:id="sidebarHeader" alignment="CENTER" spacing="14"
                  style="-fx-padding: 20 16 16 16;">

                <!-- Logo -->
                <VBox fx:id="logoContainer" alignment="CENTER"
                      style="-fx-cursor: hand; -fx-padding: 0;" maxWidth="Infinity">
                    <ImageView preserveRatio="true" fitWidth="158">
                        <image>
                            <Image url="@../icons/logo.png" />
                        </image>
                    </ImageView>
                </VBox>

                <!-- Search bar positioned before profile selector -->
                <VBox maxWidth="Infinity">
                    <TextField fx:id="navSearchField" promptText="Search activities..."
                               styleClass="search-field" maxWidth="Infinity" />
                </VBox>

                <!-- Profile selector below search -->
                <VBox alignment="CENTER" spacing="8" maxWidth="Infinity">
                    <Label text="Loaded profile"
                           style="-fx-text-fill: #e2e8f0; -fx-font-size: 13px; -fx-font-weight: bold;" />
                    <ComboBox fx:id="profileComboBox" maxWidth="Infinity" />
                </VBox>
            </VBox>

            <Separator styleClass="sidebar-divider" />

            <!-- Scrollable navigation buttons -->
            <ScrollPane hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox fx:id="buttonsContainer" styleClass="nav-button-container" spacing="8" />
            </ScrollPane>

            <!-- Pinned buttons at sidebar bottom -->
            <VBox fx:id="pinnedButtonsContainer" styleClass="sidebar-footer" spacing="8" />
        </VBox>
    </left>

    <!-- CENTER: Main content area -->
    <center>
        <StackPane fx:id="centerStack">
            <AnchorPane fx:id="mainContentPane"
                        style="-fx-background-color: #11141a;"
                        BorderPane.alignment="CENTER" />
        </StackPane>
    </center>

    <!-- BOTTOM: Status bar with reorganized element grouping -->
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="16">

            <!-- Left cluster: branding + social -->
            <VBox alignment="CENTER_LEFT" spacing="2">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label fx:id="labelVersion" text="Whiteout Survival Bot" styleClass="app-version"
                           style="-fx-text-fill: #e6edf3; -fx-font-weight: bold; -fx-font-size: 13px;" />
                    <org.kordamp.ikonli.javafx.FontIcon fx:id="iconDiscord" iconSize="18"
                        iconColor="#e6edf3" styleClass="social-icon"
                        onMouseClicked="#openDiscord" style="-fx-cursor: hand;" />
                    <org.kordamp.ikonli.javafx.FontIcon fx:id="iconGithub" iconSize="18"
                        iconColor="#e6edf3" styleClass="social-icon"
                        onMouseClicked="#openGithub" style="-fx-cursor: hand;" />
                </HBox>
            </VBox>

            <!-- Notification bubbles cluster -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <HBox fx:id="discordBubbleContainer" alignment="CENTER" styleClass="discord-bubble">
                    <Label text="Having problems? Join our Discord" styleClass="discord-bubble-text"
                           onMouseClicked="#openDiscord" />
                    <org.kordamp.ikonli.javafx.FontIcon fx:id="iconDiscordBubble" iconSize="18"
                        styleClass="discord-bubble-icon" onMouseClicked="#openDiscord" />
                    <Button fx:id="btnCloseDiscordBubble" text="✕" styleClass="discord-bubble-close"
                            onAction="#handleCloseDiscordBubble" focusTraversable="false" />
                </HBox>

                <HBox fx:id="coffeeBubbleContainer" alignment="CENTER" styleClass="coffee-bubble">
                    <Label text="Like the bot? Buy me a Coffee" styleClass="coffee-bubble-text"
                           onMouseClicked="#openCoffee" />
                    <org.kordamp.ikonli.javafx.FontIcon fx:id="iconCoffeeBubble" iconSize="18"
                        styleClass="coffee-bubble-icon" onMouseClicked="#openCoffee" />
                    <Button fx:id="btnCloseCoffeeBubble" text="✕" styleClass="coffee-bubble-close"
                            onAction="#handleCloseCoffeeBubble" focusTraversable="false" />
                </HBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Right cluster: runtime + action controls -->
            <HBox alignment="CENTER" spacing="16">
                <Label fx:id="labelRunTime" text="Uptime: 00:00:00"
                       style="-fx-text-fill: #e6edf3; -fx-font-size: 13px;" />

                <SplitMenuButton fx:id="buttonPauseResume" disable="true" mnemonicParsing="false"
                                 onAction="#handleButtonPauseResume" text="Pause"
                                 styleClass="action-button-pause" prefHeight="38" prefWidth="140"
                                 minWidth="-Infinity">
                    <items>
                        <MenuItem fx:id="menuToggleCurrentQueue" onAction="#handleToggleCurrentQueue"
                                  text="Pause current queue" />
                        <MenuItem fx:id="menuToggleAllQueues" onAction="#handleToggleAllQueues"
                                  text="Pause all queues" />
                    </items>
                </SplitMenuButton>

                <Button fx:id="buttonStartStop" disable="true" mnemonicParsing="false"
                        onAction="#handleButtonStartStop" text="Start Bot"
                        styleClass="action-button-start" prefHeight="38" prefWidth="140"
                        minWidth="-Infinity" />
            </HBox>
        </HBox>
    </bottom>

</BorderPane>
