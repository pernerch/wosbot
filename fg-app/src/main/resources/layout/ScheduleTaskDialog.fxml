<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="350.0" prefWidth="440.0"
            style="-fx-background-color: transparent; -fx-padding: 10;"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.frostguard.app.panel.scheduler.ScheduleTaskDialogController">

    <center>
        <VBox style="-fx-background-color: #1e1e24; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.6), 15, 0, 0, 8);"
              styleClass="content-card">

            <!-- Dialog header -->
            <HBox fx:id="headerBox" alignment="CENTER_LEFT" maxWidth="Infinity"
                  spacing="10" styleClass="header-blue">
                <Label fx:id="lblTaskName" maxWidth="Infinity" text="Schedule Task"
                       HBox.hgrow="ALWAYS" />
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#handleClose"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"
                        text="X" />
            </HBox>

            <!-- Form fields -->
            <VBox spacing="14" styleClass="task-section-inner">

                <HBox alignment="CENTER_LEFT" spacing="14">
                    <Label styleClass="task-field-label" text="Execution" minWidth="126" />
                    <CheckBox fx:id="cbImmediate" mnemonicParsing="false"
                              text="Execute immediately" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="14">
                    <Label styleClass="task-field-label" text="Time" minWidth="126" />
                    <TextField fx:id="timeField" promptText="HH:MM:SS"
                               HBox.hgrow="ALWAYS" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="14">
                    <Label styleClass="task-field-label" text="Recurrence" minWidth="126" />
                    <CheckBox fx:id="cbRecurring" mnemonicParsing="false"
                              text="Recurring execution" />
                </HBox>

                <Label fx:id="lblInfo" styleClass="task-card-note" text=""
                       visible="false" wrapText="true" />

                <Separator style="-fx-opacity: 0.25;" />

                <!-- Action buttons -->
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <Button fx:id="btnCancel" mnemonicParsing="false"
                            onAction="#handleCancel" styleClass="button" text="Cancel" />
                    <Button fx:id="btnSchedule" mnemonicParsing="false"
                            onAction="#handleSchedule" styleClass="action-button-timeline"
                            text="Schedule" />
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
