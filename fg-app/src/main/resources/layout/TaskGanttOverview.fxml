<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane styleClass="task-page-root" xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.frostguard.app.panel.scheduler.TaskGanttOverviewController">

    <!-- Header with title, legend, and controls -->
    <top>
        <VBox spacing="8">
            <padding>
                <Insets bottom="6" left="0" right="0" top="0" />
            </padding>

            <!-- Title row and controls -->
            <GridPane hgap="16">
                <columnConstraints>
                    <ColumnConstraints hgrow="NEVER" />
                    <ColumnConstraints hgrow="ALWAYS" />
                    <ColumnConstraints hgrow="NEVER" />
                </columnConstraints>

                <!-- Title -->
                <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: -fg-yellow;"
                       text="Task Timeline"
                       GridPane.columnIndex="0" GridPane.rowIndex="0" />

                <!-- Legend items as a flow -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <HBox alignment="CENTER_LEFT" spacing="5">
                        <Rectangle arcHeight="3" arcWidth="3" height="14" width="14"
                                   style="-fx-fill: -fg-yellow; -fx-stroke: -fg-text-dark; -fx-stroke-width: 2;" />
                        <Label styleClass="task-field-label" text="Running" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="5">
                        <Rectangle arcHeight="3" arcWidth="3" height="14" width="14"
                                   style="-fx-fill: -fg-green;" />
                        <Label styleClass="task-field-label" text="Ready" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="5">
                        <Rectangle arcHeight="3" arcWidth="3" height="14" width="14"
                                   style="-fx-fill: -fg-blue;" />
                        <Label styleClass="task-field-label" text="Scheduled" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="5">
                        <Rectangle arcHeight="3" arcWidth="3" height="14" width="14"
                                   style="-fx-fill: -fg-border-subtle; -fx-stroke: -fg-text-secondary; -fx-stroke-width: 1;" />
                        <Label styleClass="task-field-label" text="Inactive" />
                    </HBox>
                </HBox>

                <!-- Toggle controls -->
                <HBox alignment="CENTER_RIGHT" spacing="8"
                      GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <ToggleButton fx:id="toggleInactiveTasksButton" onAction="#toggleInactiveTasks"
                                  style="-fx-font-size: 11; -fx-background-color: -fg-bg-card; -fx-text-fill: -fg-text-primary; -fx-padding: 4 12; -fx-border-color: -fg-border-subtle; -fx-border-radius: 4; -fx-background-radius: 4;"
                                  text="Hide inactive" />
                    <Label styleClass="task-field-label" text="Window" />
                    <ToggleButton fx:id="toggleViewButton" onAction="#toggleTimeView"
                                  style="-fx-font-size: 11; -fx-background-color: -fg-bg-card; -fx-text-fill: -fg-yellow; -fx-padding: 4 12; -fx-border-color: -fg-yellow; -fx-border-radius: 4; -fx-background-radius: 4;"
                                  text="2 Hours" />
                </HBox>
            </GridPane>

            <!-- Time axis header row -->
            <HBox alignment="CENTER_LEFT" spacing="0">
                <padding>
                    <Insets bottom="6" />
                </padding>
                <Label style="-fx-font-weight: bold; -fx-text-fill: -fg-yellow; -fx-pref-width: 128; -fx-font-size: 12;"
                       text="Account" />
                <HBox fx:id="timeAxisHeader" alignment="CENTER_LEFT" spacing="0" />
            </HBox>
        </VBox>
    </top>

    <!-- Scrollable account rows -->
    <center>
        <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER"
                    styleClass="task-page-scroll" vbarPolicy="AS_NEEDED">
            <content>
                <VBox fx:id="vboxAccounts" spacing="0"
                      style="-fx-background-color: transparent;" />
            </content>
        </ScrollPane>
    </center>

</BorderPane>
